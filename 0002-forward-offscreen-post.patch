+
+    graph.AddPass("ForwardMainPass", std::move(mainAtt), [this, &scene, shadowRG, dirLightViewProj, lightCount, spotShadows, pointShadows, mainBatches, captureMainBatchesNoCull, instStride, transparentDraws, planarMirrorDraws, doDepthPrepass](renderGraph::PassContext& ctx) {
